#include <iostream> //input output

using namespace std;
void intro(); //intro function
void getinput(int& father,int& mother, int& end); //gets inputs
void displaysquare(int& father,int& mother); //displays squares based off inputs
void loop(int& end); //function for the loop

int main()
{
	int father, mother, end; // declare variables
	end = 1; //kick starts loop
	do { //start of loop
		intro(); //intro
		getinput(father,mother,end); // asks for imputs
		displaysquare(father,mother); // displays squares
		loop(end); // loops
	} while (end == 1); // ends loop based off user input


	return 0;
}
void intro() {
	cout<<"this program will calculate the chances of having colorblindness\n"; // opening sentence
}
void getinput(int& father,int& mother, int& end) { //starts process of getting inputs
	cout<<"if the father is colorblind enter 1, if not press 2\n"; //asks for father
	cin>>father; // takes in answer
	cout<<"if the mother is colorblind press 1, if shes a silent carrier press 2, if not press 3\n"; // asks for mother
	cin>>mother; // takes in answer
}
void displaysquare(int& father,int& mother) { //starts display function
	if (father == 1 & mother == 1) { // punnett square if both father and mother a colorblind
		cout << "              Xc       |        Y\n";
		cout << "       ---------------------------------\n";
		cout << "   Xc  |     XcXc      |       XcY     |\n";
		cout << "----------------------------------------\n";
		cout << "   Xc  |     XcXc      |       XcY     |\n";
		cout << "       ---------------------------------\n";
		cout << "50% chance your child will be a colorblind girl\n";
		cout << "50% chance your child will be a colorblind boy\n";
	} else if (father == 1 & mother == 2) { // punnett square if father is colorblind but mother is silent carrier
		cout << "              Xc       |        Y\n";
		cout << "       ---------------------------------\n";
		cout << "   Xc  |     XcXc      |       XcY     |\n";
		cout << "----------------------------------------\n";
		cout << "   X   |     XcX       |       XY      |\n";
		cout << "       ---------------------------------\n";
		cout << "25% chance your child will be a colorblind girl\n";
		cout << "25% chance you child will be a silent carrier girl\n";
		cout << "25% chance your child will be a colorblind boy\n";
		cout << "25% chance your child will be a non-colorblind boy\n";
	} else if (father == 1 & mother == 3) { // punnett square if father is colorblind and mother is not
		cout << "              Xc       |        Y\n";
		cout << "       ---------------------------------\n";
		cout << "   X   |      XcX      |        XY     |\n";
		cout << "----------------------------------------\n";
		cout << "   X   |      XcX      |        XY     |\n";
		cout << "       ---------------------------------\n";
		cout << "50% chance your child will be a silent carrier girl\n";
		cout << "50% chance your child will be a non-colorblind boy\n";
	} else if (father == 2 & mother == 1) { // punnett square if father is not colorblind but mother is colorblind
		cout << "               X       |        Y\n";
		cout << "       ---------------------------------\n";
		cout << "   Xc  |      XXc      |       XcY     |\n";
		cout << "----------------------------------------\n";
		cout << "   Xc  |      XXc      |       XcY     |\n";
		cout << "       ---------------------------------\n";
		cout << "50% chance your child will be a silent carrier girl\n";
		cout << "50% chance your child will be a colorblind boy\n";
	} else if (father == 2 & mother == 2) { // punnett square if father in not colorblind and mother is silent carrier
		cout << "               X       |        Y\n";
		cout << "       ---------------------------------\n";
		cout << "   Xc  |      XXc      |       XcY     |\n";
		cout << "----------------------------------------\n";
		cout << "   X   |      XX       |       XY      |\n";
		cout << "       ---------------------------------\n";
		cout << "25% chance your child will be a silent carrier girl\n";
		cout << "25% chance your child will be a non-colorblind girl\n";
		cout << "25% chance your child will be a colorblind boy\n";
		cout << "25% chance your child will be a non-colorblind boy\n";
	} else if (father == 2 & mother == 3) { // punnett square if father and mother is not colorblind
		cout << "               X       |        Y\n";
		cout << "       ---------------------------------\n";
		cout << "   X   |       XX      |        XY     |\n";
		cout << "----------------------------------------\n";
		cout << "   X   |       XX      |        XY     |\n";
		cout << "       ---------------------------------\n";
		cout << "50% chance your child will be a non-colorblind girl\n";
		cout << "50% chance your child will be a non-colorblind boy\n";
	} else {
		cout << "Invalid inputs\n"; // if answer is invalid
	}
}
void loop(int& end) { // end of loop
	cout << "Would you like to run another simulation press 1 for yes, for no press any other key \n"; // asks if user would like to run another simulation
	cin >> end; // takes in input for end loop
	if (end == 1) { // if 1 then redoes loop

	} else { // if not ends program
	}
}
